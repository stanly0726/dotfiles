{
    "$Schema": "https://raw.githubusercontent.com/CarterMcAlister/aerospace-layout-manager/main/layoutConfig.schema.json",
    "stashWorkspace": "S",
    "layouts": {
        "communication": {
            "workspace": "4",
            "layout": "tiles",
            "orientation": "horizontal",
            "windows": [
                {
                    "windows": [
                        {
                            "bundleId": "Mattermost.Desktop"
                        },
                        {
                            "bundleId": "ru.keepcoder.Telegram"
                        }
                    ],
                    "orientation": "vertical",
                    "size": "6/15"
                },
                {
                    "windows": [
                        {
                            "bundleId": "com.apple.Safari.WebApp.DA80CD96-6D53-4F5E-8FF1-410D111CCF98"
                        },
                        {
                            "bundleId": "com.apple.mail"
                        }
                    ],
                    "orientation": "vertical"
                }
            ]
        },
        "terminal": {
            "workspace": "1",
            "layout": "h_tiles",
            "orientation": "horizontal",
            "windows": [
                {
                    "bundleId": "com.mitchellh.ghostty"
                }
            ]
        },
        "news": {
            "workspace": "2",
            "layout": "h_tiles",
            "orientation": "horizontal",
            "windows": [
                {
                    "bundleId": "com.ranchero.NetNewsWire-Evergreen"
                }
            ]
        },
        "browser": {
            "workspace": "5",
            "layout": "h_tiles",
            "orientation": "horizontal",
            "windows": [
                {
                    "bundleId": "app.zen-browser.zen"
                }
            ]
        },
        "note": {
            "workspace": "0",
            "layout": "h_tiles",
            "orientation": "horizontal",
            "windows": [
                {
                    "bundleId": "md.obsidian"
                }
            ]
        }
    }
}
