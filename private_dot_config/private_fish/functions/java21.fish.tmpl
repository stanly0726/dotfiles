{{- if eq .osid "darwin" -}}
function java21 --wraps='export JAVA_HOME=(/usr/libexec/java_home -v 21); java --version' --description 'alias java21=export JAVA_HOME=(/usr/libexec/java_home -v 21); java --version'
    export JAVA_HOME=(/usr/libexec/java_home -v 21); java --version $argv
end
{{ end -}}
