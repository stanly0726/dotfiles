{{- if eq .osid "darwin" -}}
function java8 --wraps='export JAVA_HOME=(/usr/libexec/java_home -v 1.8); java -version' --description 'alias java8=export JAVA_HOME=(/usr/libexec/java_home -v 1.8); java -version'
    export JAVA_HOME=(/usr/libexec/java_home -v 1.8); java -version $argv
end
{{- end -}}
